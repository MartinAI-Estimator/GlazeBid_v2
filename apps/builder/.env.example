# Supabase Configuration
# Follow these steps to enable Save/Load features:

# 1. Create a free account at https://supabase.com
# 2. Create a new project (select a region close to your users)
# 3. Go to Project Settings > API
# 4. Copy the values below:

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anonymous-public-key-here

# 5. Create a copy of this file named ".env" (no .example)
# 6. Replace the placeholder values above with your actual credentials
# 7. Restart your development server

# IMPORTANT: Never commit your .env file to version control!
# The .env file is already in .gitignore

# Database Setup:
# After getting your credentials, run the SQL script below in the Supabase SQL Editor
# (Supabase Dashboard > SQL Editor > New Query):

# CREATE TABLE projects (
#   id UUID DEFAULT uuid_generate_v4() PRIMARY KEY,
#   created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
#   name TEXT NOT NULL,
#   status TEXT DEFAULT 'Draft',
#   updated_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
# );
#
# CREATE TABLE project_markups (
#   id UUID DEFAULT uuid_generate_v4() PRIMARY KEY,
#   project_id UUID REFERENCES projects(id) ON DELETE CASCADE,
#   data JSONB NOT NULL
# );
#
# CREATE TABLE project_settings (
#   id UUID DEFAULT uuid_generate_v4() PRIMARY KEY,
#   project_id UUID REFERENCES projects(id) ON DELETE CASCADE,
#   global_settings JSONB,
#   admin_settings JSONB,
#   bid_inputs JSONB
# );

# That's it! Once configured, you can:
# - Press Ctrl+S to save your project
# - Click "Open" to load saved projects
# - Your work will persist across browser sessions

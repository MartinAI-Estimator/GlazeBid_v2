{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist-electron",
    "types": ["node", "electron"]
  },
  "include": ["electron/**/*", "scripts/**/*"],
  "exclude": ["node_modules", "dist-electron", "apps"]
}

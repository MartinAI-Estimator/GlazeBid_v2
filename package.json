{
  "name": "glazebid-v2",
  "version": "2.0.0",
  "private": true,
  "main": "dist-electron/main.js",
  "description": "GlazeBid v2 — Legacy Builder UI + New Studio Takeoff Engine",
  "scripts": {
    "start": "npm run dev:builder",
    "predev:builder": "node scripts/build-preloads.mjs",
    "dev:builder": "concurrently --kill-others \"npm run dev --workspace apps/builder\" \"npm run dev --workspace apps/studio\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "predev:studio": "node scripts/build-preloads.mjs",
    "dev:studio": "concurrently --kill-others \"npm run dev --workspace apps/studio\" \"wait-on tcp:5174 && cross-env VITE_DEV_SERVER_URL=http://localhost:5174 electron .\"",
    "build:builder": "npm run build -w apps/builder",
    "build:studio": "npm run build -w apps/studio",
    "build:all": "npm run build:builder && npm run build:studio",
    "dist:win": "npm run build:all && electron-builder --win --x64",
    "dist:win:dir": "npm run build:all && electron-builder --win --x64 --dir",
    "pack": "electron-builder --dir",
    "sidecar": "cd sidecar && ../.venv/Scripts/python -m uvicorn main:app --host 127.0.0.1 --port 8100 --reload",
    "sidecar:install": "cd sidecar && ../.venv/Scripts/pip install -r requirements.txt",
    "postinstall": "electron-builder install-app-deps"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^29.1.0",
    "electron-builder": "^24.9.1",
    "electron-updater": "^6.8.3",
    "esbuild": "^0.20.0",
    "typescript": "^5.4.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.glazebid.v2",
    "productName": "GlazeBid",
    "copyright": "Copyright © 2026 GlazeBid",
    "directories": {
      "output": "release",
      "buildResources": "build-resources"
    },
    "files": [
      "dist-electron/**/*",
      "apps/builder/dist/**/*",
      "apps/studio/dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "sidecar",
        "to": "sidecar",
        "filter": [
          "**/*",
          "!__pycache__",
          "!*.pyc"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build-resources/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerIcon": "build-resources/icon.ico",
      "uninstallerIcon": "build-resources/icon.ico",
      "installerHeaderIcon": "build-resources/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "GlazeBid",
      "license": "build-resources/LICENSE.txt",
      "warningsAsErrors": false
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.business"
    },
    "linux": {
      "target": "AppImage"
    },
    "publish": {
      "provider": "github",
      "owner": "glazebid",
      "repo": "glazebid-v2"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1"
  }
}
